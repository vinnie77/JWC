"use strict";(function($){$(".nav-icon, .backdrop").on("click",function(){$(".backdrop").fadeToggle(400,"linear");$(".slide-navigation").toggleClass("open")});$(".select-picker").selectpicker();if($("#slider-range").length){let slider=document.getElementById("slider-range");noUiSlider.create(slider,{start:[0,1e7],connect:true,range:{min:0,max:1e7},step:5e4});update_slider();slider.noUiSlider.on("slide",function(values){let num1,num2;if(values[0].toString().length<=9){num1=parseInt(values[0]).toLocaleString("en-us")}else{num1=parseInt(values[0])/1e6+"m"}if(values[1].toString().length<=9){num2=parseInt(values[1]).toLocaleString("en-us")}else{num2=parseInt(values[1])/1e6+"m"}$("#amount").val("$"+num1+" - $"+num2);$("#min_price").val(parseInt(values[0]));$("#max_price").val(parseInt(values[1]))})}$("#type").on("change",function(){let status=$(this).val();let slider=document.getElementById("slider-range");$("#property-search-form input.search-status").remove();$("#property-search-form .sale-filters, #property-search-form .rent-filters").hide();$("#property-search-form .property-types").attr("disabled","disabled");if(status=="buy"){$("#property-search-form").prepend('<input type="hidden" class="search-status" name="show_in_sale" id="show_in_sale" value="true">')}if(status=="rent"){$("#property-search-form").prepend('<input type="hidden" class="search-status" name="show_in_rental" id="show_in_rental" value="true">')}if(status=="sold"){$("#property-search-form").prepend('<input type="hidden" class="search-status" name="show_in_sale" id="show_in_sale" value="true">');$("#property-search-form").prepend('<input type="hidden" class="search-status" name="sold" id="sold" value="1">')}if(status=="leased"){$("#property-search-form").prepend('<input type="hidden" class="search-status" name="show_in_rental" id="show_in_rental" value="true">');$("#property-search-form").prepend('<input type="hidden" class="search-status" name="sold" id="sold" value="1">')}if(status=="buy"||status=="sold"){$("#property-search-form .sale-filters").show();$("#property-search-form #sale-property-type").removeAttr("disabled");$("#property-search-form #rent-property-type optoin").removeAttr("selected");slider.noUiSlider.updateOptions({range:{min:0,max:1e7},step:5e4,start:[0,1e7]});update_slider(1)}if(status=="rent"||status=="leased"){$("#property-search-form .rent-filters").show();$("#property-search-form #rent-property-type").removeAttr("disabled");$("#property-search-form #sale-property-type option").removeAttr("selected");slider.noUiSlider.updateOptions({range:{min:0,max:1e4},step:250,start:[0,1e4]});update_slider(1)}$(".select-picker").selectpicker("refresh")});if($(".listings-loop").length){$(".listings-loop").slick({lazyLoad:"ondemand",centerMode:true,centerPadding:"225px",slidesToShow:2,slidesToScroll:2,autoplay:true,autoplaySpeed:2e3,responsive:[{breakpoint:1199,settings:{slidesToShow:1}},{breakpoint:1030,settings:{centerPadding:"250px",slidesToShow:1}},{breakpoint:850,settings:{slidesToShow:1,centerPadding:"125px"}},{breakpoint:768,settings:{slidesToShow:1,centerMode:false}}]})}function update_slider(skipParams=0){let num1,num2;let slider=document.getElementById("slider-range");if(!skipParams){checkURL()}let sliderValues=slider.noUiSlider.get(true);if(sliderValues[0].toString().length<=6){num1=parseInt(sliderValues[0]).toLocaleString("en-us")}else{num1=parseInt(sliderValues[0])/1e6+"m"}if(sliderValues[1].toString().length<=6){num2=parseInt(sliderValues[1]).toLocaleString("en-us")}else{num2=parseInt(sliderValues[1])/1e6+"m"}$("#amount").val("$"+num1+" - $"+num2);$("#min_price").val(sliderValues[0]);$("#max_price").val(sliderValues[1])}function checkURL(){let minPrice,maxPrice;let searchParams=new URLSearchParams(window.location.search);let slider=document.getElementById("slider-range");if(searchParams.has("min_price")){minPrice=searchParams.get("min_price")}else{minPrice=0}if(searchParams.has("max_price")){maxPrice=searchParams.get("max_price")}else{if($("#type").val()=="buy"||$("#type").val()=="sold"){maxPrice=1e7}else{maxPrice=1e4}}if($("#type").val()=="rent"||$("#type").val()=="leased"){slider.noUiSlider.updateOptions({range:{min:0,max:1e4},step:250})}slider.noUiSlider.updateOptions({start:[minPrice,maxPrice]})}if($("#keyword").length){let searchItems=properties;$("#keyword").autocomplete({appendTo:".listings-search",delay:0,source:function(request,response){response($.ui.autocomplete.filter(searchItems,extractLast(request.term)))},focus:function(){return false},select:function(event,ui){var terms=split(this.value);terms.pop();terms.push(ui.item.value);terms.push("");this.value=terms.join(", ");return false},response:function(event,ui){if(!ui.content.length){var noResult={value:"",label:"",category:"No results found"};ui.content.push(noResult)}}});function split(val){return val.split(/,\s*/)}function extractLast(term){return split(term).pop()}}if($(".property-images").length){$(".image-gallery").slick({lazyLoad:"ondemand",slidesToShow:1,nextArrow:".slick-arrows .arrow-next",prevArrow:".slick-arrows .arrow-prev",waitForAnimate:false,infinite:false})}if($(".sidebar").length){$(".content, .sidebar").theiaStickySidebar({additionalMarginTop:30})}if($("a.read-more").length){$("a.read-more").on("click",function(e){e.preventDefault();$(this).parent().parent().children(".advert-description").toggleClass("closed","open");if($(this).parent().parent().children(".advert-description.closed").length){$(this).text("Read more")}else{$(this).text("Read less")}})}if($(".enquiry-form").length){const forms=document.querySelectorAll("form.enquiry-form, .modal form.enquiry-form");$.each(forms,function(form){forms[form].addEventListener("submit",formProcessor)})}function formProcessor(event){event.preventDefault();const form=event.target;const formFields=form.elements;form.parentElement.querySelector(".alert-danger").style.display="none";let valid="";if(formFields.name.value.length<1){formFields.name.style.border="1px solid red";formFields.name.placeholder="Name is required";valid+="A"}else{formFields.name.style.border="1px solid #ced4da"}if(formFields.phone.value.length<1){formFields.phone.style.border="1px solid red";formFields.phone.placeholder="Phone is required";valid+="A"}else{formFields.phone.style.border="1px solid #ced4da"}if(formFields.email.value.length<1||formFields.email.value.length>1&&!formFields.email.value.match(/^([a-z0-9._-]+@[a-z0-9._-]+\.[a-z]{2,4}$)/i)){formFields.email.style.border="1px solid red";formFields.email.placeholder="A valid email is required";valid+="A"}else{formFields.email.style.border="1px solid #ced4da"}if(formFields.enquiry.value.length<1){formFields.enquiry.style.border="1px solid red";formFields.enquiry.placeholder="Enquiry is required";valid+="A"}else{formFields.enquiry.style.border="1px solid #ced4da"}if(valid==""){form.parentElement.querySelector(".alert-info").style.display="block";const valid_str=$(form).serialize();const protocol=location.protocol;const ajax_url=protocol+"//"+document.domain+"/?tbajax";$.post(ajax_url,valid_str+"&action=iproperty_enquiry_subnmit",function(response){if(response=="success"){form.parentElement.querySelector(".alert-info").style.display="none";form.parentElement.querySelector(".alert-success").style.display="block"}else{form.parentElement.querySelector(".alert-info").style.display="none";form.parentElement.querySelector(".alert-danger").style.display="block"}})}else{form.parentElement.querySelector(".alert-danger").style.display="block"}}})(jQuery);